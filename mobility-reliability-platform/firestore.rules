rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function membershipPath(tenantId) {
      return /databases/$(database)/documents/tenants/$(tenantId)/memberships/$(request.auth.uid);
    }

    function tenantPath(tenantId) {
      return /databases/$(database)/documents/tenants/$(tenantId);
    }

    function hasCanonicalRoles(membership) {
      return membership.roles is list
        && membership.roles.size() > 0
        && membership.roles.hasOnly([
          'beneficiary',
          'guardian',
          'case_worker',
          'repairer',
          'tenant_admin',
          'auditor'
        ]);
    }

    function isCurrentlyValid(membership) {
      return membership.valid_from is timestamp
        && membership.valid_from <= request.time
        && (
          !('valid_to' in membership)
          || membership.valid_to == null
          || (membership.valid_to is timestamp && request.time < membership.valid_to)
        );
    }

    function isActiveMember(tenantId) {
      return signedIn()
        && exists(tenantPath(tenantId))
        && get(tenantPath(tenantId)).data.tenant_id == tenantId
        && get(tenantPath(tenantId)).data.status == 'active'
        && exists(membershipPath(tenantId))
        && get(membershipPath(tenantId)).data.tenant_id == tenantId
        && get(membershipPath(tenantId)).data.firebase_uid == request.auth.uid
        && get(membershipPath(tenantId)).data.status == 'active'
        && hasCanonicalRoles(get(membershipPath(tenantId)).data)
        && isCurrentlyValid(get(membershipPath(tenantId)).data);
    }

    function isOperationalStaff(tenantId) {
      return isActiveMember(tenantId)
        && get(membershipPath(tenantId)).data.roles.hasAny([
          'case_worker',
          'tenant_admin'
        ]);
    }

    function hasOwnPerson(tenantId) {
      return isActiveMember(tenantId)
        && 'person_id' in get(membershipPath(tenantId)).data
        && get(membershipPath(tenantId)).data.person_id is string
        && get(membershipPath(tenantId)).data.person_id.size() > 0;
    }

    function hasMatchingTenant(tenantId) {
      return 'tenant_id' in resource.data
        && resource.data.tenant_id == tenantId;
    }

    function isOwnPerson(tenantId, personId) {
      return hasOwnPerson(tenantId)
        && get(membershipPath(tenantId)).data.person_id == personId;
    }

    function canReadPersonScopedResource(tenantId) {
      return hasMatchingTenant(tenantId)
        && (
          isOperationalStaff(tenantId)
          || (
            hasOwnPerson(tenantId)
            && 'person_id' in resource.data
            && resource.data.person_id == get(membershipPath(tenantId)).data.person_id
          )
        );
    }

    function canReadRelationship(tenantId) {
      return hasMatchingTenant(tenantId)
        && (
          isOperationalStaff(tenantId)
          || (
            hasOwnPerson(tenantId)
            && (
              (
                'from_person_id' in resource.data
                && resource.data.from_person_id == get(membershipPath(tenantId)).data.person_id
              )
              || (
                'to_person_id' in resource.data
                && resource.data.to_person_id == get(membershipPath(tenantId)).data.person_id
              )
            )
          )
        );
    }

    match /tenants/{tenantId} {
      allow get: if isActiveMember(tenantId);
      allow list, write: if false;

      match /memberships/{firebaseUid} {
        allow get: if firebaseUid == request.auth.uid && isActiveMember(tenantId);
        allow list, write: if false;
      }

      // Person-scoped records are visible to operational staff or the member
      // whose canonical membership person_id owns the record. Mutations remain
      // behind authenticated backend commands for Stage 1.
      match /people/{personId} {
        allow get: if hasMatchingTenant(tenantId)
          && 'person_id' in resource.data
          && resource.data.person_id == personId
          && (isOperationalStaff(tenantId) || isOwnPerson(tenantId, personId));
        allow list: if false;
        allow write: if false;
      }

      match /personRelationships/{relationshipId} {
        allow get, list: if canReadRelationship(tenantId);
        allow write: if false;
      }

      match /devices/{deviceId} {
        allow get, list: if isOperationalStaff(tenantId) && hasMatchingTenant(tenantId);
        allow write: if false;

        match /state/{stateId} {
          allow get, list: if isOperationalStaff(tenantId);
          allow write: if false;
        }
      }

      match /deviceAssignments/{assignmentId} {
        allow get, list: if canReadPersonScopedResource(tenantId);
        allow write: if false;
      }

      match /partCatalog/{partId} {
        allow get, list: if isActiveMember(tenantId) && hasMatchingTenant(tenantId);
        allow write: if false;
      }

      match /componentInstallations/{componentId} {
        allow get, list: if isOperationalStaff(tenantId) && hasMatchingTenant(tenantId);
        allow write: if false;
      }

      match /repairs/{repairId} {
        allow get, list: if isOperationalStaff(tenantId) && hasMatchingTenant(tenantId);
        allow write: if false;

        match /items/{repairItemId} {
          allow get, list: if isOperationalStaff(tenantId);
          allow write: if false;
        }
      }

      match /inspections/{inspectionId} {
        allow get, list: if isOperationalStaff(tenantId) && hasMatchingTenant(tenantId);
        allow write: if false;

        match /observations/{observationId} {
          allow get, list: if isOperationalStaff(tenantId);
          allow write: if false;
        }
      }

      match /trips/{tripId} {
        allow get, list: if canReadPersonScopedResource(tenantId);
        allow write: if false;
      }

      match /consentRevisions/{consentRevisionId} {
        allow get, list: if canReadPersonScopedResource(tenantId);
        allow write: if false;
      }

      match /alerts/{alertId} {
        allow get, list: if canReadPersonScopedResource(tenantId);
        allow write: if false;

        match /deliveries/{deliveryId} {
          allow get, list: if isOperationalStaff(tenantId);
          allow write: if false;
        }
      }

      match /modelPredictions/{predictionId} {
        allow get, list: if isOperationalStaff(tenantId) && hasMatchingTenant(tenantId);
        allow write: if false;
      }

      match /evidenceFacts/{factId} {
        allow get, list: if isOperationalStaff(tenantId) && hasMatchingTenant(tenantId);
        allow write: if false;
      }

      match /reportRuns/{reportRunId} {
        allow get, list: if isOperationalStaff(tenantId) && hasMatchingTenant(tenantId);
        allow write: if false;

        match /claims/{claimId} {
          allow get, list: if isOperationalStaff(tenantId);
          allow write: if false;
        }
      }

      // These paths contain PII, ingestion internals, authorization state, or
      // operational control data and are never exposed through client rules.
      match /privatePeople/{document=**} {
        allow read, write: if false;
      }

      match /privateOrganization/{document=**} {
        allow read, write: if false;
      }

      match /appInstallations/{document=**} {
        allow read, write: if false;
      }

      match /consentStates/{document=**} {
        allow read, write: if false;
      }

      match /ingestReceipts/{document=**} {
        allow read, write: if false;
      }

      match /ingestIdempotency/{document=**} {
        allow read, write: if false;
      }

      match /ingestClientBatches/{document=**} {
        allow read, write: if false;
      }

      match /domainEvents/{document=**} {
        allow read, write: if false;
      }

      match /projectionCheckpoints/{document=**} {
        allow read, write: if false;
      }

      match /recoveryWorkerState/{document=**} {
        allow read, write: if false;
      }

      match /deadLetters/{document=**} {
        allow read, write: if false;
      }

      match /externalIdentifiers/{document=**} {
        allow read, write: if false;
      }

      match /dataAccessGrants/{document=**} {
        allow read, write: if false;
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }

    match /authzIndex/{document=**} {
      allow read, write: if false;
    }

    match /globalPartCatalog/{document=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
