rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function membershipPath(tenantId) {
      return /databases/$(database)/documents/tenants/$(tenantId)/memberships/$(request.auth.uid);
    }

    function hasCanonicalRoles(membership) {
      return membership.roles is list
        && membership.roles.size() > 0
        && membership.roles.hasOnly([
          'beneficiary',
          'guardian',
          'case_worker',
          'repairer',
          'tenant_admin',
          'auditor'
        ]);
    }

    function isCurrentlyValid(membership) {
      return membership.valid_from is timestamp
        && membership.valid_from <= request.time
        && (
          !('valid_to' in membership)
          || membership.valid_to == null
          || (membership.valid_to is timestamp && request.time < membership.valid_to)
        );
    }

    function isActiveMember(tenantId) {
      return signedIn()
        && exists(membershipPath(tenantId))
        && get(membershipPath(tenantId)).data.tenant_id == tenantId
        && get(membershipPath(tenantId)).data.firebase_uid == request.auth.uid
        && get(membershipPath(tenantId)).data.status == 'active'
        && hasCanonicalRoles(get(membershipPath(tenantId)).data)
        && isCurrentlyValid(get(membershipPath(tenantId)).data);
    }

    match /tenants/{tenantId} {
      allow read: if isActiveMember(tenantId);
      allow write: if false;

      match /memberships/{firebaseUid} {
        allow get: if firebaseUid == request.auth.uid && isActiveMember(tenantId);
        allow list, write: if false;
      }

      // Tenant-scoped domain projections are readable by a current member.
      // Mutations remain behind authenticated backend commands for Stage 1.
      match /people/{personId} {
        allow read: if isActiveMember(tenantId);
        allow write: if false;
      }

      match /personRelationships/{relationshipId} {
        allow read: if isActiveMember(tenantId);
        allow write: if false;
      }

      match /devices/{deviceId} {
        allow read: if isActiveMember(tenantId);
        allow write: if false;

        match /state/{stateId} {
          allow read: if isActiveMember(tenantId);
          allow write: if false;
        }
      }

      match /deviceAssignments/{assignmentId} {
        allow read: if isActiveMember(tenantId);
        allow write: if false;
      }

      match /partCatalog/{partId} {
        allow read: if isActiveMember(tenantId);
        allow write: if false;
      }

      match /componentInstallations/{componentId} {
        allow read: if isActiveMember(tenantId);
        allow write: if false;
      }

      match /repairs/{repairId} {
        allow read: if isActiveMember(tenantId);
        allow write: if false;

        match /items/{repairItemId} {
          allow read: if isActiveMember(tenantId);
          allow write: if false;
        }
      }

      match /inspections/{inspectionId} {
        allow read: if isActiveMember(tenantId);
        allow write: if false;

        match /observations/{observationId} {
          allow read: if isActiveMember(tenantId);
          allow write: if false;
        }
      }

      match /trips/{tripId} {
        allow read: if isActiveMember(tenantId);
        allow write: if false;
      }

      match /consentRevisions/{consentRevisionId} {
        allow read: if isActiveMember(tenantId);
        allow write: if false;
      }

      match /alerts/{alertId} {
        allow read: if isActiveMember(tenantId);
        allow write: if false;

        match /deliveries/{deliveryId} {
          allow read: if isActiveMember(tenantId);
          allow write: if false;
        }
      }

      match /modelPredictions/{predictionId} {
        allow read: if isActiveMember(tenantId);
        allow write: if false;
      }

      match /evidenceFacts/{factId} {
        allow read: if isActiveMember(tenantId);
        allow write: if false;
      }

      match /reportRuns/{reportRunId} {
        allow read: if isActiveMember(tenantId);
        allow write: if false;

        match /claims/{claimId} {
          allow read: if isActiveMember(tenantId);
          allow write: if false;
        }
      }

      // These paths contain PII, ingestion internals, authorization state, or
      // operational control data and are never exposed through client rules.
      match /privatePeople/{document=**} {
        allow read, write: if false;
      }

      match /privateOrganization/{document=**} {
        allow read, write: if false;
      }

      match /appInstallations/{document=**} {
        allow read, write: if false;
      }

      match /ingestReceipts/{document=**} {
        allow read, write: if false;
      }

      match /ingestIdempotency/{document=**} {
        allow read, write: if false;
      }

      match /ingestClientBatches/{document=**} {
        allow read, write: if false;
      }

      match /domainEvents/{document=**} {
        allow read, write: if false;
      }

      match /projectionCheckpoints/{document=**} {
        allow read, write: if false;
      }

      match /deadLetters/{document=**} {
        allow read, write: if false;
      }

      match /externalIdentifiers/{document=**} {
        allow read, write: if false;
      }

      match /dataAccessGrants/{document=**} {
        allow read, write: if false;
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }

    match /authzIndex/{document=**} {
      allow read, write: if false;
    }

    match /globalPartCatalog/{document=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
