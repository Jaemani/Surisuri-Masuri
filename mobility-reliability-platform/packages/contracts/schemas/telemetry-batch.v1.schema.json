{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.internal/telemetry-batch.v1.schema.json",
  "title": "TelemetryBatchV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "batchId",
    "idempotencyKey",
    "tenantId",
    "actorId",
    "mobilityDeviceId",
    "sessionId",
    "consentVersion",
    "sentAt",
    "samples"
  ],
  "properties": {
    "schemaVersion": { "const": "telemetry-batch.v1" },
    "batchId": { "type": "string", "format": "uuid" },
    "idempotencyKey": { "type": "string", "minLength": 16, "maxLength": 128 },
    "tenantId": { "type": "string", "format": "uuid" },
    "actorId": { "type": "string", "format": "uuid" },
    "mobilityDeviceId": { "type": "string", "format": "uuid" },
    "sessionId": { "type": "string", "format": "uuid" },
    "consentVersion": { "type": "string", "minLength": 1, "maxLength": 64 },
    "sentAt": { "type": "string", "format": "date-time" },
    "samples": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": { "$ref": "#/$defs/sample" }
    }
  },
  "$defs": {
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sampleId",
        "sequence",
        "capturedAt",
        "latitude",
        "longitude",
        "horizontalAccuracyM",
        "source"
      ],
      "properties": {
        "sampleId": { "type": "string", "format": "uuid" },
        "sequence": { "type": "integer", "minimum": 0 },
        "capturedAt": { "type": "string", "format": "date-time" },
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
        "horizontalAccuracyM": { "type": ["number", "null"], "minimum": 0 },
        "altitudeM": { "type": ["number", "null"] },
        "speedMps": { "type": ["number", "null"], "minimum": 0 },
        "headingDegrees": { "type": ["number", "null"], "minimum": 0, "exclusiveMaximum": 360 },
        "activityHint": {
          "type": "string",
          "enum": ["unknown", "stationary", "walking", "wheeled", "motor_vehicle"]
        },
        "isMockLocation": { "type": ["boolean", "null"] },
        "source": { "const": "phone_gps" }
      }
    }
  }
}
