{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.internal/telemetry-batch.v2.schema.json",
  "title": "TelemetryBatchV2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "clientBatchId",
    "tenantId",
    "deviceId",
    "tripId",
    "clientSessionId",
    "installationId",
    "consentRevisionId",
    "sentAt",
    "samples"
  ],
  "properties": {
    "schemaVersion": { "const": "telemetry-batch.v2" },
    "clientBatchId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string", "format": "uuid" },
    "deviceId": { "type": "string", "format": "uuid" },
    "tripId": { "type": "string", "format": "uuid" },
    "clientSessionId": { "type": "string", "format": "uuid" },
    "installationId": { "type": "string", "format": "uuid" },
    "consentRevisionId": { "type": "string", "format": "uuid" },
    "sentAt": { "type": "string", "format": "date-time" },
    "samples": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": { "$ref": "#/$defs/sample" }
    }
  },
  "$defs": {
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clientSampleId",
        "sequence",
        "capturedAt",
        "latitude",
        "longitude",
        "horizontalAccuracyM",
        "source"
      ],
      "properties": {
        "clientSampleId": { "type": "string", "format": "uuid" },
        "sequence": { "type": "integer", "minimum": 0 },
        "capturedAt": { "type": "string", "format": "date-time" },
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
        "horizontalAccuracyM": { "type": ["number", "null"], "minimum": 0 },
        "altitudeM": { "type": ["number", "null"] },
        "speedMps": { "type": ["number", "null"], "minimum": 0 },
        "headingDegrees": { "type": ["number", "null"], "minimum": 0, "exclusiveMaximum": 360 },
        "activityHint": {
          "type": "string",
          "enum": ["unknown", "stationary", "walking", "wheeled", "motor_vehicle"]
        },
        "isMockLocation": { "type": ["boolean", "null"] },
        "source": { "const": "phone_gps" }
      }
    }
  }
}
